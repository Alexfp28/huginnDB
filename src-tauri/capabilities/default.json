{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the HuginnDB app window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "window-state:default",
    "updater:default",
    "process:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/*" },
        { "url": "http://github.com/*" },
        { "url": "mailto:*" }
      ]
    }
  ]
}
